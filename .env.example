# Build mode selects which BASE_URL to use. dev | stage | prod.
VITE_BUILD_MODE=dev

# Backend (Django + DRF). Mirrors gyaan_buddy/.env.example.
# IMPORTANT: the Flutter code in lib/utils/env.dart hard-codes "/api" as the
# version suffix and IGNORES the API_VERSION env var. Mirror that exactly.
VITE_BASE_URL_DEV=https://api-dev.gyaanbuddy.com
VITE_BASE_URL_STAGE=https://api-stage.gyaanbuddy.com
VITE_BASE_URL_PROD=https://api.gyaanbuddy.com
VITE_API_PREFIX=/api

# Network timeouts (ms). Flutter used seconds; converted to milliseconds.
VITE_CONNECT_TIMEOUT=30000
VITE_RECEIVE_TIMEOUT=30000
VITE_SEND_TIMEOUT=30000

# --- Dev safety nets ---
# When true, login accepts any non-empty admission #/password and creates a
# fake session. Lets you click through every screen with no real backend.
# Set to false (or unset) for real backend testing.
VITE_DEV_MOCK_AUTH=false

# When true, /api/* calls go through the Vite dev server, which proxies to
# VITE_BASE_URL_<mode>. Bypasses browser CORS entirely. Only takes effect in
# `npm run dev`; production builds always hit the backend directly.
# (When this is true, axios uses an empty baseURL so paths stay relative.)
VITE_USE_PROXY=false

# Firebase web config — copy from gyaan_buddy/lib/firebase_options.dart
# (web platform block) or from gyaan_buddy/web/index.html. Optional for login;
# required only for Firebase Cloud Messaging web push (Tier 5).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_VAPID_KEY=

# PostHog analytics (Tier 5).
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com
