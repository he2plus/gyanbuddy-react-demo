# =============================================================================
# .env — committed defaults applied to EVERY build (local + Vercel).
# Lower priority than .env.local (which is gitignored), so on a dev machine
# your .env.local takes over and points at the real backend.
# On Vercel there is no .env.local, so the values here drive the production
# build — which means MOCK AUTH is ON in the live demo. Any non-empty
# admission # + password works; the app then serves fixture data from the
# in-process mock layer in src/api/*.
# =============================================================================

VITE_BUILD_MODE=dev

# Mock everything on the live demo so reviewers can poke around without
# needing the Django backend hosted publicly.
VITE_DEV_MOCK_AUTH=true

# These are only used when MOCK_AUTH=false (local real-backend mode).
VITE_USE_PROXY=true
VITE_BASE_URL_DEV=http://localhost:8000
VITE_API_PREFIX=/api
