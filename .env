# =============================================================================
# .env — committed defaults applied to EVERY build (local + Vercel).
# Lower priority than .env.local (which is gitignored), so on a dev machine
# your .env.local takes over.
#
# LIVE DEMO: these values drive the Vercel production build. The app now talks
# to the REAL backend at https://gyanbuddy.ai. Because VITE_USE_PROXY=true the
# axios baseURL stays relative ("/api"), and vercel.json rewrites /api/* to the
# real backend SERVER-SIDE — so the browser makes a same-origin call and CORS
# never enters the picture. Log in with a real student account.
# =============================================================================

VITE_BUILD_MODE=prod

# Use the REAL backend on the live demo (no more in-process fixture data).
VITE_DEV_MOCK_AUTH=false

# Keep requests same-origin ("/api/...") so the vercel.json proxy (prod) and the
# vite dev-server proxy (local) forward them to the backend — bypassing CORS.
VITE_USE_PROXY=true

# Real backend (used when not proxying). The /api proxy target also lives in
# vercel.json for the Vercel build.
VITE_BASE_URL_PROD=https://gyanbuddy.ai
VITE_BASE_URL_DEV=http://localhost:8000
VITE_API_PREFIX=/api
